# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://saus_user:password@localhost:5432/saus_cms"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-at-least-64-chars"
JWT_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:3000"
# Origin(s) of the public static SAUS website, allowed to POST the contact form.
# Comma-separated. e.g. "https://saus-s52a.vercel.app,http://localhost:8080"
PUBLIC_SITE_URL="http://localhost:8080"

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800   # 50 MB in bytes

# ─── AWS S3 (optional – leave blank to use local storage) ─────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ─── Email (for notifications) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="SAUS CMS <noreply@saus.org.za>"
# Where public contact-form submissions are emailed (if SMTP is set).
# Leave SMTP_USER/PASS blank to disable email — messages are still saved to the DB.
CONTACT_TO="Secretariat@saus.org.za"

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="SAUS CMS"
APP_URL="https://admin.saus.org.za"
